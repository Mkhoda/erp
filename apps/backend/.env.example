# ──────────────────────────────────────────────────────────────────
# Arzesh ERP — Backend Environment Variables
# Copy this file to .env and fill in the values.
# ──────────────────────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Database ────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/arzesh_erp?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/arzesh_erp"

# ── JWT ─────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-strong-random-secret

# ── CORS ────────────────────────────────────────────────────────
# CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# ── Bale Bot API ────────────────────────────────────────────────
# Used for sending OTP messages via Bale Safir v3.
# Get BALE_BOT_ID from your bot's numeric ID.
# Get BALE_SAFIR_API_KEY from Bale Business Panel → Safir settings.
BALE_API_KEY=1016716104:your_bot_token_here
BALE_BOT_ID=1016716104
BALE_SAFIR_API_KEY=your_safir_api_access_key_here
BALE_MOCK=true
LOG_BALE_VERBOSE=true

# ── File Upload ─────────────────────────────────────────────────
# MAX_FILE_SIZE=10485760
# UPLOAD_DIRECTORY=uploads

# ── Prisma ──────────────────────────────────────────────────────
PRISMA_CLIENT_ENGINE_TYPE=library
                                                                                                                                            
# CORS settings                                                                                                                             
CORS_ORIGIN=http://91.92.181.146:3000,http://91.92.181.146,http://localhost:3000,http://erp.arzesh.net,http://37.235.18.227:5530            
                                                                                                                                            
# Security settings                                                                                                                         
BCRYPT_ROUNDS=12                                                                                                                            
JWT_EXPIRATION=24h                                                                                                                          
REFRESH_TOKEN_EXPIRATION=7d                                                                                                                 
                                                                                                                                            
# Bale Bot API (for getMe, sendMessage, etc.)                                                                                               
                                                                                                                                            
BALE_API_KEY=1016716104:a3fmjDglo2Ns9ODpu9iWY3ajqNvA75uEUvE                                                                                 
                                                                                                                                            
                                                                                                                                            
                                                                                                                                            
# Bale Safir API v3 (for sending OTP via bulk messaging)                                                                                    
                                                                                                                                            
# bot_id: extracted from BALE_API_KEY (first part before ":")                                                                               
                                                                                                                                            
BALE_BOT_ID=1016716104                                                                                                                      
                                                                                                                                            
# api-access-key: get this from Bale Business Panel → Safir settings                                                                        
                                                                                                                                            
# If you don't have a separate Safir key, you can try using BALE_CLIENT_ID here