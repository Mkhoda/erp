generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String?   @unique
  // Phone number used for OTP-based auth. Optional for legacy users; unique when present.
  phone     String?   @unique
  // Password is optional when users sign up via OTP and haven't set a password yet.
  password  String?
  firstName String
  lastName  String
  role      Role      @default(USER)
  // When true, user cannot log in (soft-disable instead of hard delete)
  disabled    Boolean   @default(false)
  // Max concurrent active sessions (0 = unlimited). Default 1 = single-session.
  maxSessions Int       @default(1)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  // Many-to-many memberships in departments (additional to primary departmentId)
  userDepartments UserDepartment[]
  timesheets Timesheet[]
  assetAssignments AssetAssignment[]        @relation("AssetAssignmentUser")
  assignedByAssignments AssetAssignment[]   @relation("AssetAssignmentAssignedBy")
  assetCostsCreated AssetCost[] @relation("AssetCostCreatedBy")
  assetsCreated Asset[]
  aiUsage       AiUsage[]
  conversations Conversation[]
  memories      UserMemory[]
  todos         Todo[]
  quotas        UserQuota[]
  // ── Attendance & Workforce ──
  // Card number used to match imported device punches to this user.
  attendanceCardNo String? @unique
  rawAttendance         RawAttendanceRecord[]
  attendanceDays        AttendanceDay[]
  attendanceOverrides   AttendanceOverride[]    @relation("AttnOverrideBy")
  attendanceRule        UserAttendanceRule?
  shiftAssignments      ShiftAssignment[]
  leaveRequests         LeaveRequest[]          @relation("LeaveUser")
  attendanceRequests    AttendanceRequest[]     @relation("AttnReqUser")
  attendanceNotifications AttendanceNotification[] @relation("AttnNotifUser")
  // ── Security ──
  tokenVersion Int      @default(1)
  sessions     Session[]
  auditLogs    AuditLog[] @relation("UserAuditLogs")
  // ── Messaging ──
  chatMembers   ChatMember[]   @relation("UserChatMemberships")
  chatMessages  ChatMessage[]  @relation("ChatMessageSender")
  chatReactions ChatReaction[] @relation("UserChatReactions")
  chatReads     ChatRead[]     @relation("UserChatReads")
  presence      UserPresence?  @relation("UserPresenceRecord")
  // ── Ticketing ──
  ticketsRequested   Ticket[]             @relation("TicketRequester")
  ticketsAssigned    Ticket[]             @relation("TicketAssignee")
  ticketsRelated     Ticket[]             @relation("TicketRelatedUser")
  ticketComments     TicketComment[]      @relation("TicketCommentAuthor")
  ticketAttachments  TicketAttachment[]   @relation("TicketAttachmentUploader")
  ticketEvents       TicketEvent[]        @relation("TicketEventActor")
  ticketNotifications TicketNotification[] @relation("TicketNotifUser")
  managedDeptConfigs TicketDeptManager[]
  defaultAssigneeConfigs TicketDeptAssignee[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum Role {
  ADMIN
  MANAGER
  USER
  EXPERT
}

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  users     User[]
  userDepartments UserDepartment[]
  assetAssignments AssetAssignment[]
  pagePermissions PagePermission[]
  ticketConfig    TicketDepartmentConfig?
  tickets         Ticket[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Timesheet {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  date      DateTime
  hours     Float
  project   String?
  note      String?
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Asset Management

enum AssetCondition {
  NEW
  USED_GOOD
  DEFECTIVE
}

enum AssetAvailability {
  AVAILABLE
  IN_USE
  CONSUMED
  MAINTENANCE
  RETIRED
  LOST
}

enum BarcodeType {
  QR
  CODE128
}

enum AssetCostType {
  PURCHASE
  REPAIR
  MAINTENANCE
  OTHER
}

model AssetType {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  assets      Asset[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AssetCategory {
  id          String          @id @default(cuid())
  name        String          @unique
  description String?
  codePrefix  String?
  parentId    String?
  parent      AssetCategory?  @relation("AssetCategoryToAssetCategory", fields: [parentId], references: [id])
  children    AssetCategory[] @relation("AssetCategoryToAssetCategory")
  assets      Asset[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Asset {
  id             String            @id @default(cuid())
  name           String
  barcode        String            @unique
  oldBarcode     String?
  description    String?
  typeId         String
  type           AssetType        @relation(fields: [typeId], references: [id])
  condition      AssetCondition
  categoryId     String
  category       AssetCategory     @relation(fields: [categoryId], references: [id])
  availability   AssetAvailability @default(AVAILABLE)
  barcodeType    BarcodeType       @default(QR)
  serialNumber   String?
  location       String?
  purchaseDate   DateTime?
  cost           Float?
  consumedAt     DateTime?
  images         AssetImage[]
  assignments    AssetAssignment[]
  maintenances   AssetMaintenance[]
  costs          AssetCost[]
  createdById    String?
  createdBy      User?             @relation(fields: [createdById], references: [id])
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model AssetImage {
  id        String  @id @default(cuid())
  assetId   String
  asset     Asset   @relation(fields: [assetId], references: [id], onDelete: Cascade)
  url       String
  caption   String?
  createdAt DateTime @default(now())
}

model AssetAssignment {
  id            String     @id @default(cuid())
  assetId       String
  asset         Asset      @relation(fields: [assetId], references: [id])
  userId        String?
  user          User?      @relation("AssetAssignmentUser", fields: [userId], references: [id])
  departmentId  String?
  department    Department? @relation(fields: [departmentId], references: [id])
  buildingId    String?
  building      Building?  @relation(fields: [buildingId], references: [id])
  floorId       String?
  floor         Floor?     @relation(fields: [floorId], references: [id])
  roomId        String?
  room          Room?      @relation(fields: [roomId], references: [id])
  assignedAt    DateTime   @default(now())
  returnedAt    DateTime?
  purpose       String?    @default("استفاده")
  note          String?
  assignedById  String?
  assignedBy    User?      @relation("AssetAssignmentAssignedBy", fields: [assignedById], references: [id])
}

model AssetMaintenance {
  id          String   @id @default(cuid())
  assetId     String
  asset       Asset    @relation(fields: [assetId], references: [id])
  startDate   DateTime
  endDate     DateTime?
  cost        Float?
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AssetCost {
  id          String        @id @default(cuid())
  assetId     String
  asset       Asset         @relation(fields: [assetId], references: [id])
  type        AssetCostType
  amount      Float
  date        DateTime      @default(now())
  note        String?
  createdById String?
  createdBy   User?         @relation("AssetCostCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([assetId, date])
}

model Building {
  id               String            @id @default(cuid())
  name             String            @unique
  floors           Floor[]
  rooms            Room[]
  assetAssignments AssetAssignment[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model Floor {
  id               String            @id @default(cuid())
  name             String
  buildingId       String
  building         Building          @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  rooms            Room[]
  assetAssignments AssetAssignment[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([buildingId, name])
}

model Room {
  id               String            @id @default(cuid())
  name             String
  buildingId       String
  floorId          String?
  building         Building          @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  floor            Floor?            @relation(fields: [floorId], references: [id])
  assetAssignments AssetAssignment[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([buildingId, floorId, name])
}

// Many-to-many relation between User and Department (memberships)
model UserDepartment {
  userId       String
  departmentId String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@id([userId, departmentId])
}

// Department-based page access control
// role: '*' = applies to ANY role in that department; or a specific Role value e.g. 'MANAGER'
model PagePermission {
  id            String      @id @default(cuid())
  departmentId  String
  department    Department  @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  page          String
  role          String      @default("*")
  canRead       Boolean     @default(true)
  canWrite      Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([departmentId, page, role])
  @@index([page])
}

// Registered dashboard pages — source of truth for the menu system.
// isActive=false disables the page system-wide (hidden from menu for all users including admin).
model Page {
  id        String   @id @default(cuid())
  path      String   @unique
  label     String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// OTP codes used for phone-based authentication and password reset
model Otp {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone, createdAt])
}

// Persistent chat conversations per user
model Conversation {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  title      String?
  provider   String
  model      String?
  summary        String?  // compact summary replacing older messages
  rollingContext String?  // auto-updated context after each exchange
  isArchived     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  messages   ConversationMessage[]

  @@index([userId, updatedAt])
}

model ConversationMessage {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String       // "user" | "assistant"
  content        String
  latencyMs      Int?
  createdAt      DateTime @default(now())

  @@index([conversationId, createdAt])
}

// User memory: facts the AI should remember across conversations
model UserMemory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// AI provider configurations — managed via admin panel
model AiProvider {
  id        String   @id @default(cuid())
  name      String                  // Display name e.g. "OpenAI GPT-4o"
  type      String                  // "openai" | "anthropic" | "gemini" | "deepseek" | "agnes" | "custom"
  apiKey    String                  // API key (stored as-is; use env-var or vault in production)
  apiUrl    String?                 // Custom API base URL (optional, has sensible default)
  model     String?                 // Model identifier e.g. "gpt-4o"
  isActive  Boolean  @default(true)
  config    Json?                   // Additional provider-specific config
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userQuotas   UserQuota[]
  defaultQuota DefaultQuota?
}

// AI usage tracking — records each API call for token consumption analytics
model AiUsage {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  providerType String                  // "openai" | "anthropic" | "gemini" | "deepseek" | "agnes" | "custom"
  providerName String?                 // Custom display name e.g. "GPT-4o Production"
  model       String?                  // Model used e.g. "gpt-4o"
  prompt      String                   // User's input/prompt (truncated)
  promptTokens   Int    @default(0)
  completionTokens Int  @default(0)
  totalTokens     Int   @default(0)
  latencyMs       Int   @default(0)
  success         Boolean @default(true)
  errorMsg        String?
  rawResponse     String?  // Raw API response for debugging (truncated)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([providerType])
  @@index([createdAt])
}

// Per-user token quota per AI model (AiProvider)
model UserQuota {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerId   String     // references a specific configured AiProvider (model)
  provider     AiProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  monthlyLimit Int        // 0 = unlimited
  usedTokens   Int        @default(0)
  periodStart  DateTime
  periodEnd    DateTime
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([userId, providerId])
  @@index([userId])
  @@index([providerId])
}

// Platform-wide default quota per AI model (auto-assigned to users on first use)
model DefaultQuota {
  id           String     @id @default(cuid())
  providerId   String     @unique
  provider     AiProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  monthlyLimit Int        // 0 = unlimited
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// Personal to-do items per user
model Todo {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  done      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// HTTP request/response logs for admin debugging
model RequestLog {
  id         String   @id @default(cuid())
  method     String
  path       String
  statusCode Int?
  userId     String?
  body       String?     // Truncated request body JSON
  response   String?     // Truncated response JSON
  latencyMs  Int?
  errorMsg   String?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([path])
  @@index([statusCode])
}

// ════════════════════════════════════════════════════════════════════
// Attendance & Workforce Management
// ════════════════════════════════════════════════════════════════════

enum PunchDirection {
  IN
  OUT
  UNKNOWN
}

enum AttendanceStatus {
  PRESENT
  LATE
  EARLY_LEAVE
  ABSENT
  INCOMPLETE
  LEAVE
  MISSION
  REMOTE_WORK
  HOLIDAY
  COMPANY_HOLIDAY
  WEEKEND
}

enum HolidayType {
  OFFICIAL
  COMPANY
  HALF_DAY
  CALENDAR
}

enum ShiftType {
  FIXED
  ROTATING
  NIGHT
  WEEKLY_ROTATION
  MONTHLY_ROTATION
  TWENTY_FOUR_FORTY_EIGHT
}

enum LeaveKind {
  VACATION
  SICK
  MISSION
  REMOTE_WORK
  HOURLY
}

enum AttnRequestType {
  CHECK_IN_FIX
  CHECK_OUT_FIX
  FULL_DAY_FIX
  EXPLANATION
  LEAVE
}

enum AttnRequestStatus {
  PENDING
  MANAGER_APPROVED
  HR_APPROVED
  APPROVED
  REJECTED
}

enum SyncRunStatus {
  RUNNING
  SUCCESS
  FAILED
  PARTIAL
}

enum AttnNotifType {
  MISSING_PUNCH
  ABSENCE
  DELAY
  EXCESSIVE_OVERTIME
  SYNC_FAILURE
  DEVICE_OFFLINE
}

enum AttnNotifChannel {
  IN_APP
  BALE
  EMAIL
}

// ── Integration / Sync settings (one row per external source) ──
model AttendanceSource {
  id              String   @id @default(cuid())
  name            String                            // e.g. "EOSDB Main"
  driver          String   @default("mssql")        // mssql | mysql | http (extensible)
  host            String
  port            Int      @default(1433)
  database        String
  username        String
  password        String                            // encrypted at rest (see crypto.util)
  tableName       String   @default("dbo.TimeRecords")
  timeZone        String   @default("Asia/Tehran")
  syncEnabled     Boolean  @default(false)
  syncIntervalSec Int      @default(300)
  batchSize       Int      @default(1000)
  initialSyncDate DateTime?
  initialRecordId Int      @default(0)
  autoRetry       Boolean  @default(true)
  retryCount      Int      @default(3)
  lastRecordId    Int      @default(0)              // cursor: last imported RecordID
  lastSyncAt      DateTime?
  lastSuccessAt   DateTime?
  lastFailureAt   DateTime?
  lastError       String?
  devices         AttendanceDevice[]
  syncLogs        AttendanceSyncLog[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ── DeviceCode → friendly name + direction hint + offline detection ──
model AttendanceDevice {
  id          String           @id @default(cuid())
  sourceId    String
  source      AttendanceSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  deviceCode  String
  name        String
  direction   PunchDirection   @default(UNKNOWN)    // IN-only / OUT-only readers
  lastSeenAt  DateTime?
  isActive    Boolean          @default(true)

  @@unique([sourceId, deviceCode])
}

// ── Per-run sync audit log ──
model AttendanceSyncLog {
  id           String           @id @default(cuid())
  sourceId     String
  source       AttendanceSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  status       SyncRunStatus
  trigger      String                                // "scheduled" | "manual"
  fromRecordId Int
  toRecordId   Int
  imported     Int              @default(0)
  skipped      Int              @default(0)
  errorDetail  String?
  startedAt    DateTime         @default(now())
  finishedAt   DateTime?

  @@index([sourceId, startedAt])
}

// ── Layer 1: immutable raw imported records ──
model RawAttendanceRecord {
  id         String   @id @default(cuid())
  sourceId   String
  recordId   Int                                     // device RecordID
  cardNo     String
  mDate      String?                                 // raw mDate as received
  sDate      String?
  rTime      String?
  rType      String?                                 // raw RType
  deviceCode String?
  punchAt    DateTime                                // normalized, tz-adjusted timestamp
  userId     String?                                 // resolved from cardNo (null = unmapped)
  user       User?    @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([sourceId, recordId])                     // duplicate prevention
  @@index([userId, punchAt])
  @@index([cardNo, punchAt])
}

// ── Layer 2: computed daily attendance ──
model AttendanceDay {
  id                String           @id @default(cuid())
  userId            String
  user              User             @relation(fields: [userId], references: [id])
  gregDate          DateTime                          // midnight of the work date
  jYear             Int
  jMonth            Int
  jDay              Int
  firstCheckIn      DateTime?
  lastCheckOut      DateTime?
  workedMinutes          Int              @default(0)
  overtimeMinutes        Int              @default(0)   // اضافه‌کاری روزهای عادی
  holidayOvertimeMinutes Int              @default(0)   // تعطیل‌کاری (ضریب متفاوت)
  delayMinutes           Int              @default(0)
  earlyLeaveMinutes      Int              @default(0)
  deficitMinutes         Int              @default(0)   // shortfall vs required hours (delay+earlyLeave+unworked)
  nightMinutes           Int              @default(0)
  leaveMinutes      Int              @default(0)        // approved leave for the day (hourly or full)
  status            AttendanceStatus
  isHolidayWork     Boolean          @default(false)
  shiftId           String?
  shift             Shift?           @relation(fields: [shiftId], references: [id])
  hasOverride       Boolean          @default(false)
  computedAt        DateTime         @default(now())

  @@unique([userId, gregDate])
  @@index([jYear, jMonth])
  @@index([status])
}

// ── Layer 3: audited manual overrides ──
model AttendanceOverride {
  id          String            @id @default(cuid())
  userId      String
  gregDate    DateTime
  newCheckIn  DateTime?
  newCheckOut DateTime?
  forceStatus AttendanceStatus?
  leaveMinutes Int?                                     // hourly-leave minutes granted for the day
  reason      String
  createdById String
  createdBy   User              @relation("AttnOverrideBy", fields: [createdById], references: [id])
  requestId   String?                                // links to approved AttendanceRequest
  createdAt   DateTime          @default(now())

  @@index([userId, gregDate])
}

// ── Global work schedule / rules (default + named schedules) ──
model WorkSchedule {
  id             String   @id @default(cuid())
  name           String   @unique @default("default")
  isDefault      Boolean  @default(false)
  startTime      String   @default("08:00")           // "HH:mm"
  endTime        String   @default("17:00")
  dailyMinutes   Int      @default(500)                 // required work (8:20)
  weeklyMinutes  Int      @default(2640)
  lunchMinutes   Int      @default(0)
  // Window-based attendance: arrival allowed in [checkInStart, checkInEnd],
  // departure expected in [checkOutStart, checkOutEnd].
  checkInStart   String   @default("06:30")
  checkInEnd     String   @default("09:00")
  checkOutStart  String   @default("14:50")
  checkOutEnd    String   @default("17:20")
  flexEnabled    Boolean  @default(false)
  flexInStart    String?  @default("07:30")
  flexInEnd      String?  @default("09:00")
  graceMinutes   Int      @default(0)
  workDays       Int[]    @default([6, 0, 1, 2, 3])    // JS getDay(): Sat..Wed (Thu/Fri weekend)
  otMinThreshold Int      @default(30)
  otMaxDaily     Int      @default(240)
  otMaxMonthly   Int      @default(3600)
  otRounding     Int      @default(15)                 // round OT to nearest N minutes
  annualLeaveDays Int     @default(26)                 // yearly paid-leave entitlement (days)
  userRules      UserAttendanceRule[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ── Per-user override of WorkSchedule ──
// Employee classification — drives whether overtime/lateness are computed.
enum EmployeeType {
  FULL_TIME // تمام‌وقت: اضافه‌کار، تاخیر و تعجیل محاسبه می‌شود
  HOURLY    // ساعتی: بدون اضافه‌کار/تاخیر؛ فقط ساعت حضور مهم است
}

model UserAttendanceRule {
  id           String        @id @default(cuid())
  userId       String        @unique
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduleId   String?
  schedule     WorkSchedule? @relation(fields: [scheduleId], references: [id])
  employeeType EmployeeType  @default(FULL_TIME)
  startTime    String?
  endTime      String?
  dailyMinutes Int?
  checkInStart  String?
  checkInEnd    String?
  checkOutStart String?
  checkOutEnd   String?
  graceMinutes Int?
  flexEnabled  Boolean?
  otAllowed    Boolean       @default(true)
  otMaxDaily   Int?
  otMaxMonthly Int?
  updatedAt    DateTime      @updatedAt
}

model Shift {
  id           String            @id @default(cuid())
  name         String            @unique
  type         ShiftType
  startTime    String                                  // "HH:mm" (NIGHT may cross midnight)
  endTime      String
  breakMinutes Int               @default(0)
  cycleDays    Int?                                    // rotating / 24-48 patterns
  pattern      Json?                                   // e.g. ["D","D","N","off"]
  isActive     Boolean           @default(true)
  assignments  ShiftAssignment[]
  calendar     ShiftCalendarDay[]
  days         AttendanceDay[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model ShiftAssignment {
  id        String    @id @default(cuid())
  shiftId   String
  shift     Shift     @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  startDate DateTime
  endDate   DateTime?

  @@index([userId, startDate])
}

// ── Materialized resolved shift per user per day (for rotations) ──
model ShiftCalendarDay {
  id       String   @id @default(cuid())
  shiftId  String
  shift    Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  userId   String
  gregDate DateTime
  isOff    Boolean  @default(false)

  @@unique([userId, gregDate])
}

model Holiday {
  id          String      @id @default(cuid())
  title       String
  type        HolidayType
  startDate   DateTime
  endDate     DateTime                                 // single day → start == end
  recurring   Boolean     @default(false)              // repeats yearly by jMonth/jDay
  jMonth      Int?
  jDay        Int?
  note        String?
  scheduleIds String[]    @default([])                 // bound work-schedule (group) ids; empty = all groups
  createdAt   DateTime    @default(now())

  @@index([startDate, endDate])
}

// Per-group, per-weekday overrides of working hours within a date range. Applied
// on top of the resolved WorkSchedule for matching days (e.g. "every Wednesday
// in Q1, the امریه group works 08:00–13:00"). null fields inherit the base.
model ScheduleOverride {
  id            String   @id @default(cuid())
  title         String?
  scheduleIds   String[] @default([])   // affected groups; empty = all groups
  weekdays      Int[]    @default([])    // JS getDay() 0..6; empty = every day in range
  startDate     DateTime                 // range start (work date, inclusive)
  endDate       DateTime                 // range end (inclusive)
  isOff         Boolean  @default(false) // mark matched days as non-working
  checkInStart  String?
  checkInEnd    String?
  checkOutStart String?
  checkOutEnd   String?
  dailyMinutes  Int?
  lunchMinutes  Int?
  createdAt     DateTime @default(now())

  @@index([startDate, endDate])
}

model LeaveRequest {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation("LeaveUser", fields: [userId], references: [id])
  kind         LeaveKind
  startDate    DateTime
  endDate      DateTime
  startTime    String?                                 // for HOURLY
  endTime      String?
  reason       String?
  attachment   String?
  status       AttnRequestStatus @default(PENDING)
  managerById  String?
  hrById       String?
  decidedAt    DateTime?
  decisionNote String?
  createdAt    DateTime          @default(now())

  @@index([userId, startDate])
  @@index([status])
}

// ── Manual correction / explanation workflow ──
model AttendanceRequest {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation("AttnReqUser", fields: [userId], references: [id])
  type         AttnRequestType
  gregDate     DateTime
  requestedIn  DateTime?
  requestedOut DateTime?
  // For leave/mission/remote-work declarations — the status to force on approval.
  targetStatus AttendanceStatus?
  leaveMinutes Int?                                     // hourly-leave duration (minutes)
  description  String
  attachment   String?
  status       AttnRequestStatus @default(PENDING)
  managerById  String?
  hrById       String?
  decidedAt    DateTime?
  decisionNote String?
  createdAt    DateTime          @default(now())

  @@index([userId, gregDate])
  @@index([status])
}

model AttendanceNotification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation("AttnNotifUser", fields: [userId], references: [id])
  type      AttnNotifType
  channel   AttnNotifChannel @default(IN_APP)
  title     String
  body      String
  isRead    Boolean          @default(false)
  meta      Json?
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
}

// ════════════════════════════════════════════════════════════════════
// Security & Session Management
// ════════════════════════════════════════════════════════════════════

// Active login sessions — one row per login. Embedded in JWT payload as `sid`.
// Revocation is soft-delete: set isRevoked = true.
model Session {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  issuedAt       DateTime  @default(now())
  expiresAt      DateTime
  lastSeenAt     DateTime  @default(now())
  ipAddress      String?
  userAgent      String?   @db.Text
  deviceType     String?
  deviceModel    String?
  browser        String?
  browserVersion String?
  os             String?
  platform       String?
  authMethod     String    @default("password")
  rememberMe     Boolean   @default(false)
  isRevoked      Boolean   @default(false)
  revokedAt      DateTime?
  revokedById    String?

  @@index([userId])
  @@index([isRevoked, expiresAt])
  @@index([lastSeenAt])
}

// Global auth configuration — single row, singleton pattern (id = "singleton").
// globalTokenVersion increments on any settings change to force all tokens invalid.
model AuthSettings {
  id                    String   @id @default("singleton")
  accessTokenTtlSec     Int      @default(86400)
  rememberMeTtlSec      Int      @default(2592000)
  idleTimeoutSec        Int      @default(0)
  maxSessionLifetimeSec Int      @default(0)
  globalTokenVersion    Int      @default(1)
  updatedAt             DateTime @updatedAt
  updatedById           String?
}

// Security audit log — login, logout, password change, session revoke, settings change.
model AuditLog {
  id        String   @id @default(cuid())
  timestamp DateTime @default(now())
  userId    String?
  user      User?    @relation("UserAuditLogs", fields: [userId], references: [id], onDelete: SetNull)
  adminId   String?
  ipAddress String?
  userAgent String?
  action    String
  result    String   @default("SUCCESS")
  details   Json?
  sessionId String?

  @@index([userId])
  @@index([action])
  @@index([timestamp])
}

// ════════════════════════════════════════════════════════════════════
// Internal Real-Time Messaging
// ════════════════════════════════════════════════════════════════════

enum ChatConvType {
  DIRECT
  GROUP
}

enum ChatMsgType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  VOICE
  DOCUMENT
  CODE
  LINK
  SYSTEM
}

enum PresenceStatus {
  ONLINE
  AWAY
  BUSY
  OFFLINE
}

model ChatConversation {
  id        String       @id @default(cuid())
  type      ChatConvType @default(DIRECT)
  name      String?
  avatarUrl String?
  members   ChatMember[]
  messages  ChatMessage[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([updatedAt])
}

model ChatMember {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User             @relation("UserChatMemberships", fields: [userId], references: [id], onDelete: Cascade)
  role           String           @default("MEMBER")
  lastReadAt     DateTime?
  isArchived     Boolean          @default(false)
  joinedAt       DateTime         @default(now())

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User             @relation("ChatMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  type           ChatMsgType      @default(TEXT)
  content        String?
  isEdited       Boolean          @default(false)
  editedAt       DateTime?
  isDeleted      Boolean          @default(false)
  deletedForAll  Boolean          @default(false)
  replyToId      String?
  replyTo        ChatMessage?     @relation("MessageReplies", fields: [replyToId], references: [id])
  replies        ChatMessage[]    @relation("MessageReplies")
  metadata       Json?
  attachments    ChatAttachment[]
  reactions      ChatReaction[]
  readBy         ChatRead[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model ChatAttachment {
  id        String      @id @default(cuid())
  messageId String
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  type      ChatMsgType @default(DOCUMENT)
  url       String
  name      String
  size      Int
  mimeType  String?
  width     Int?
  height    Int?
  duration  Int?
  createdAt DateTime    @default(now())

  @@index([messageId])
}

model ChatReaction {
  messageId String
  userId    String
  emoji     String
  user      User        @relation("UserChatReactions", fields: [userId], references: [id], onDelete: Cascade)
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@id([messageId, userId, emoji])
  @@index([messageId])
}

model ChatRead {
  messageId String
  userId    String
  user      User        @relation("UserChatReads", fields: [userId], references: [id], onDelete: Cascade)
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  readAt    DateTime    @default(now())

  @@id([messageId, userId])
  @@index([userId])
}

model UserPresence {
  userId     String         @id
  user       User           @relation("UserPresenceRecord", fields: [userId], references: [id], onDelete: Cascade)
  status     PresenceStatus @default(OFFLINE)
  lastSeenAt DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

// System-wide settings managed via admin panel (Bale OTP, etc.)
model SystemSettings {
  id              String   @id @default("singleton")
  // Bale Safir OTP gateway
  baleSafirApiKey String?  // api-access-key from Bale Business Panel → Safir
  baleBotId       String?  // numeric bot ID
  baleMock        Boolean  @default(false) // skip real SMS in dev/test
  updatedAt       DateTime @updatedAt
  updatedById     String?
}

model ChatSettings {
  id                     String   @id @default("singleton")
  maxFileSizeMb          Int      @default(10)
  allowedExtensions      String[] @default(["jpg", "jpeg", "png", "gif", "pdf", "doc", "docx", "xls", "xlsx", "zip", "mp4", "mp3"])
  messageEditWindowSec   Int      @default(300)
  messageDeleteWindowSec Int      @default(300)
  retentionDays          Int      @default(0)
  updatedAt              DateTime @updatedAt
  updatedById            String?
}

// ════════════════════════════════════════════════════════════════════
// Help Desk / Ticketing System
// ════════════════════════════════════════════════════════════════════

enum TicketStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  WAITING_USER
  USER_REPLIED
  RESOLVED
  CLOSED
  CANCELLED
  REJECTED
  REOPENED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// Singleton configuration for ticketing system
model TicketSettings {
  id                 String   @id @default("singleton")
  maxFileSizeMb      Int      @default(10)
  allowedExtensions  String[] @default(["jpg","jpeg","png","gif","pdf","doc","docx","xls","xlsx","zip","txt"])
  autoCloseAfterDays Int      @default(7)
  allowUserPriority  Boolean  @default(false)
  ticketPrefix       String   @default("TKT")
  updatedAt          DateTime @updatedAt
  updatedById        String?
}

// Per-department ticketing configuration
model TicketDepartmentConfig {
  id                    String     @id @default(cuid())
  departmentId          String     @unique
  department            Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  isEnabled             Boolean    @default(false)
  // SLA in business hours
  slaFirstResponseHours Int        @default(4)
  slaResolutionHours    Int        @default(24)
  // Work hours for SLA calculation (HH:MM)
  workHoursStart        String     @default("08:00")
  workHoursEnd          String     @default("17:00")
  // Work days: 6=Sat,0=Sun,1=Mon,2=Tue,3=Wed,4=Thu,5=Fri (Persian week: 6,0,1,2,3)
  workDays              Int[]      @default([6, 0, 1, 2, 3])
  autoAssignRoundRobin  Boolean    @default(false)
  notifyOnCreate        Boolean    @default(true)
  notifyOnReply         Boolean    @default(true)
  notifyOnClose         Boolean    @default(true)
  updatedAt             DateTime   @updatedAt

  categories       TicketCategory[]
  managers         TicketDeptManager[]
  defaultAssignees TicketDeptAssignee[]
}

// Junction: managers of a ticket department config
model TicketDeptManager {
  configId String
  userId   String
  config   TicketDepartmentConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  user     User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([configId, userId])
}

// Junction: default assignees for a department config (used for round-robin)
model TicketDeptAssignee {
  configId String
  userId   String
  config   TicketDepartmentConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  user     User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([configId, userId])
}

// Predefined ticket subjects per department — users MUST pick one, no free text
model TicketCategory {
  id           String                 @id @default(cuid())
  configId     String
  config       TicketDepartmentConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  isActive     Boolean                @default(true)
  order        Int                    @default(0)
  // Override department-level SLA for this specific category
  slaFirstResponseHours Int?
  slaResolutionHours    Int?
  tickets      Ticket[]

  @@unique([configId, name])
  @@index([configId, isActive])
}

// Main Ticket entity
model Ticket {
  id           String         @id @default(cuid())
  // Human-readable sequential number (e.g. TKT-1042)
  number       Int            @default(autoincrement())
  departmentId String
  department   Department     @relation(fields: [departmentId], references: [id])
  categoryId   String
  category     TicketCategory @relation(fields: [categoryId], references: [id])

  requesterId  String
  requester    User           @relation("TicketRequester", fields: [requesterId], references: [id])
  assigneeId   String?
  assignee     User?          @relation("TicketAssignee", fields: [assigneeId], references: [id])

  status   TicketStatus   @default(OPEN)
  priority TicketPriority @default(MEDIUM)

  description String @db.Text

  // Optional references
  relatedUserId String?
  relatedUser   User?  @relation("TicketRelatedUser", fields: [relatedUserId], references: [id])

  tags      String[]
  ccUserIds String[]

  // SLA timestamps
  dueAt          DateTime?
  firstResponseAt DateTime?
  resolvedAt     DateTime?
  closedAt       DateTime?
  isOverSla      Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments      TicketComment[]
  attachments   TicketAttachment[]
  events        TicketEvent[]
  notifications TicketNotification[]
  slaMetric     TicketSlaMetric?

  @@index([status])
  @@index([departmentId, status])
  @@index([requesterId])
  @@index([assigneeId])
  @@index([createdAt])
  @@index([number])
}

// Replies AND internal notes in a single table (isInternal flag)
model TicketComment {
  id         String    @id @default(cuid())
  ticketId   String
  ticket     Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId   String
  author     User      @relation("TicketCommentAuthor", fields: [authorId], references: [id])
  content    String    @db.Text
  isInternal Boolean   @default(false)
  isEdited   Boolean   @default(false)
  editedAt   DateTime?
  isDeleted  Boolean   @default(false)
  replyToId  String?
  replyTo    TicketComment?  @relation("CommentReplies", fields: [replyToId], references: [id])
  replies    TicketComment[] @relation("CommentReplies")

  attachments TicketAttachment[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ticketId, createdAt])
  @@index([ticketId, isInternal])
}

// File attachments — linked to ticket directly or to a specific comment
model TicketAttachment {
  id           String         @id @default(cuid())
  ticketId     String
  ticket       Ticket         @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  commentId    String?
  comment      TicketComment? @relation(fields: [commentId], references: [id], onDelete: SetNull)
  uploadedById String
  uploadedBy   User           @relation("TicketAttachmentUploader", fields: [uploadedById], references: [id])
  url          String
  name         String
  size         Int
  mimeType     String?
  createdAt    DateTime       @default(now())

  @@index([ticketId])
}

// Full activity timeline — every meaningful action becomes an event row
model TicketEvent {
  id       String   @id @default(cuid())
  ticketId String
  ticket   Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actorId  String?
  actor    User?    @relation("TicketEventActor", fields: [actorId], references: [id], onDelete: SetNull)
  // CREATED | ASSIGNED | REASSIGNED | TRANSFERRED | STATUS_CHANGED | PRIORITY_CHANGED |
  // COMMENT_ADDED | INTERNAL_NOTE | ATTACHMENT_ADDED | CLOSED | REOPENED | SLA_BREACHED
  type     String
  meta     Json?
  createdAt DateTime @default(now())

  @@index([ticketId, createdAt])
}

// In-app notifications for ticket events
model TicketNotification {
  id       String  @id @default(cuid())
  userId   String
  user     User    @relation("TicketNotifUser", fields: [userId], references: [id], onDelete: Cascade)
  ticketId String
  ticket   Ticket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  // ASSIGNED | REPLIED | MENTIONED | STATUS_CHANGED | TRANSFERRED | SLA_WARNING | OVER_SLA
  type     String
  title    String
  body     String
  isRead   Boolean @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([ticketId])
}

// Computed SLA metrics per ticket — updated whenever relevant timestamps change
model TicketSlaMetric {
  id       String @id @default(cuid())
  ticketId String @unique
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  // Targets (copied from dept config at creation time)
  slaFirstResponseHours Int
  slaResolutionHours    Int

  // Elapsed durations in minutes (null until the event happens)
  minutesToFirstResponse  Int?
  minutesToFirstAssignment Int?
  minutesToResolution     Int?
  minutesToClose          Int?

  // Business-hours breakdown
  businessMinutesTotal  Int @default(0)
  waitingUserMinutes    Int @default(0)
  waitingDeptMinutes    Int @default(0)

  // SLA breach tracking
  firstResponseDueAt DateTime?
  resolutionDueAt    DateTime?
  firstResponseBreached Boolean @default(false)
  resolutionBreached    Boolean @default(false)

  updatedAt DateTime @updatedAt
}
